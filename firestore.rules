rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "cameiliadwiyanti@gmail.com" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidRoom(data) {
      return data.keys().hasAll(['name', 'hostId', 'status', 'currentLayout', 'participants', 'createdAt', 'capturedPhotos']) &&
             data.name is string && data.name.size() <= 100 &&
             data.hostId is string && data.hostId.size() <= 128 &&
             data.status in ['waiting', 'countdown', 'capturing', 'completed'] &&
             data.currentLayout is string &&
             data.participants is list && data.participants.size() <= 50 &&
             data.capturedPhotos is map;
    }

    // Room Rules
    match /rooms/{roomId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (
        existing().hostId == request.auth.uid ||
        request.auth.uid in existing().participants
      );
      
      allow create: if isSignedIn() && 
                      isValidId(roomId) &&
                      isValidRoom(incoming()) &&
                      incoming().hostId == request.auth.uid &&
                      incoming().createdAt == request.time;
                      
      allow update: if isSignedIn() &&
                      isValidId(roomId) &&
                      (
                        // Host can update anything valid
                        (existing().hostId == request.auth.uid && isValidRoom(incoming())) ||
                        // Participants can join or update photos
                        (
                          incoming().diff(existing()).affectedKeys().hasAny(['participants', 'capturedPhotos']) &&
                          incoming().hostId == existing().hostId &&
                          incoming().name == existing().name &&
                          incoming().createdAt == existing().createdAt &&
                          (
                            // Join action
                            (incoming().participants.size() > existing().participants.size() &&
                             request.auth.uid in incoming().participants) ||
                            // Photo update action
                            (incoming().capturedPhotos.keys().hasAny([request.auth.uid]))
                          )
                        )
                      );
      
      allow delete: if isAdmin() || (isSignedIn() && existing().hostId == request.auth.uid);
    }

    // Template Rules
    match /templates/{templateId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Sticker Rules
    match /stickers/{stickerId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Admin list
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if false; 
    }
  }
}
